laravel_configure_mail() {
    if var_true "${LARAVEL_CONFIGURE_MAIL}" ; then
        print_debug "[configure_mail] Updating Mail"

        if [ -n "${MAIL_TYPE}" ]; then
            laravel_env_update MAIL_TYPE "${MAIL_TYPE}"
        fi
        if [ -n "${MAIL_FROM_ADDRESS}" ]; then
            laravel_env_update MAIL_FROM_ADDRESS "${MAIL_FROM_ADDRESS}"
        fi
        if [ -n "${MAIL_FROM_NAME}" ]; then
            laravel_env_update MAIL_FROM_NAME "${MAIL_FROM_NAME}"
        fi

        if [ -z "${MAIL_HOST}" ]; then
            if [ -n "${SMTP_HOST}" ]; then
                MAIL_HOST="${SMTP_HOST}"
            fi
        fi
        if [ -n "${MAIL_HOST}" ]; then
            laravel_env_update MAIL_HOST "${MAIL_HOST}"
        fi

        if [ -z "${MAIL_PORT}" ]; then
            if [ -n "${SMTP_PORT}" ]; then
                MAIL_PORT="${SMTP_PORT}"
            fi
        fi
        if [ -n "${MAIL_PORT}" ]; then
            laravel_env_update MAIL_PORT "${MAIL_PORT}"
        fi

        transform_var file \
                            MAIL_USERNAME \
                            MAIL_PASSWORD \
                            SMTP_USER \
                            SMTP_PASS
        if [ -z "${MAIL_USERNAME}" ]; then
            if [ -n "${SMTP_USER}" ]; then
                MAIL_USERNAME="${SMTP_USER}"
            fi
        fi
        if [ -n "${MAIL_USERNAME}" ]; then
            laravel_env_update MAIL_USERNAME "${MAIL_USERNAME}"
        fi
        if [ -z "${MAIL_PASSWORD}" ]; then
            if [ -n "${SMTP_PASS}" ]; then
                MAIL_PASSWORD="${SMTP_PASS}"
            fi
        fi
        if [ -n "${MAIL_PASSWORD}" ]; then
            laravel_env_update MAIL_PASSWORD "${MAIL_PASSWORD}"
        fi

        if [ -z "${MAIL_ENCRYPTION}" ]; then
            if [ -n "${SMTP_ENCRYPTION}" ]; then
                MAIL_ENCRYPTION="${SMTP_ENCRYPTION}"
            fi
        fi
        if [ -n "${MAIL_ENCRYPTION}" ]; then
            laravel_env_update MAIL_ENCRYPTION "${MAIL_ENCRYPTION}"
        fi
    fi
}

laravel_configure_vite_hmr() {
    if var_true "${ENABLE_LARAVEL_VITE_HMR}" ; then
        _hmr_host="${VITE_HMR_HOST:-}"
        if [ -z "${_hmr_host}" ] && [ -f "${NGINX_WEBROOT%/}"/.env ]; then
            _app_url=$(grep -i "^APP_URL=" "${NGINX_WEBROOT%/}"/.env 2>/dev/null | cut -d'=' -f2 | sed 's/#.*//' | tr -d '"' | tr -d "'" | xargs)
            if [ -n "${_app_url}" ]; then
                _hmr_host=$(echo "${_app_url}" | sed -n 's|https\?://\([^:/]*\).*|\1|p')
            fi
        fi

        if [ -n "${_hmr_host}" ]; then
            print_info "[configure_vite_hmr] Configuring Vite HMR for remote development (host: ${_hmr_host})"
            if [ -f "${NGINX_WEBROOT%/}"/.env ]; then
                if grep -qi "^VITE_HMR_HOST=" "${NGINX_WEBROOT%/}"/.env 2>/dev/null; then
                    sed -i --follow-symlinks "s|^VITE_HMR_HOST=.*|VITE_HMR_HOST=${_hmr_host}|" "${NGINX_WEBROOT%/}"/.env
                else
                    echo "VITE_HMR_HOST=${_hmr_host}" | write_file -a "${NGINX_WEBROOT%/}"/.env
                fi
            fi

            if [ -f "${NGINX_WEBROOT%/}"/vite.config.js ]; then
                if ! grep -q "VITE_HMR_HOST" "${NGINX_WEBROOT%/}"/vite.config.js 2>/dev/null; then
                    print_info "Patching vite.config.js with HMR configuration"
                    sudo -u "${NGINX_USER}" php -r '
                        $f = $argv[1];
                        $c = file_get_contents($f);

                        if (strpos($c, "VITE_HMR_HOST") !== false) exit(0);

                        $serverBlock = "    server: {\n"
                            . "        host: '\''0.0.0.0'\'',\n"
                            . "        ...(process.env.VITE_HMR_HOST ? {\n"
                            . "            origin: \`https://\${process.env.VITE_HMR_HOST}\`,\n"
                            . "            hmr: { host: process.env.VITE_HMR_HOST, protocol: '\''wss'\'', clientPort: 443, path: '\''/@vite/hmr'\'' },\n"
                            . "        } : {}),\n"
                            . "        watch: {\n"
                            . "            ignored: ['\''**/storage/framework/views/**'\''],\n"
                            . "        },\n"
                            . "    },";

                        if (preg_match("/    server\s*:\s*\{.*?\n    \},/s", $c)) {
                            $c = preg_replace("/    server\s*:\s*\{.*?\n    \},/s", $serverBlock, $c);
                        } elseif (strpos($c, "server:") === false) {
                            $c = preg_replace("/(plugins\s*:\s*\[.*?\],)/s", "$1\n" . $serverBlock, $c);
                        }

                        file_put_contents($f, $c);
                    ' "${NGINX_WEBROOT%/}"/vite.config.js
                fi
            fi
        fi
    else
        if [ -f "${NGINX_WEBROOT%/}"/.env ] && grep -qi "^VITE_HMR_HOST=" "${NGINX_WEBROOT%/}"/.env 2>/dev/null; then
            print_debug "[configure_vite_hmr] Removing Vite HMR configuration"
            sed -i --follow-symlinks "/^VITE_HMR_HOST=/d" "${NGINX_WEBROOT%/}"/.env
        fi
    fi
}

laravel_db_is_populated() {
    local _table="${LARAVEL_DB_FRESH_CHECK_TABLE}"
    case "${DB_TYPE,,}" in
        sqlite* )
            local _path="${DB_DATABASE:-${NGINX_WEBROOT%/}/database/database.sqlite}"
            case "${_path}" in /*) ;; *) _path="${NGINX_WEBROOT%/}/${_path}" ;; esac
            if [ ! -f "${_path}" ]; then
                return 1
            fi
            if sqlite3 "${_path}" ".tables" 2>/dev/null | tr ' ' '\n' | grep -qx "${_table}"; then
                return 0
            fi
            return 1
        ;;
        mariadb | mysql )
            local _ssl=""
            case "${DB_SSL,,}" in
                true)  _ssl="--ssl" ;;
                false) _ssl="--skip-ssl" ;;
            esac
            if ! mariadb ${_ssl} \
                        -u"${DB_USER}" \
                        -p"${DB_PASS}" \
                        -h"${DB_HOST}" \
                        -P"${DB_PORT}" \
                        -e "SELECT 1;" "${DB_NAME}" > /dev/null 2>&1; then
                print_error "Cannot connect to ${DB_HOST}:${DB_PORT}/${DB_NAME} (DB_SSL=${DB_SSL:-unset}) - exiting before any migrations run"
                mariadb ${_ssl} \
                        -u"${DB_USER}" \
                        -p"${DB_PASS}" \
                        -h"${DB_HOST}" \
                        -P"${DB_PORT}" \
                        -e "SELECT 1;" "${DB_NAME}"
                exit 1
            fi
            if mariadb ${_ssl} \
                        -u"${DB_USER}" \
                        -p"${DB_PASS}" \
                        -h"${DB_HOST}" \
                        -P"${DB_PORT}" \
                        -e "SHOW TABLES LIKE '${_table}';" "${DB_NAME}" 2>/dev/null \
                    | grep -qx "${_table}"; then
                return 0
            fi
            return 1
        ;;
        psql | pgsql | postgres* )
            export PGPASSWORD="${DB_PASS}"
            local _sslmode="${DB_SSL_MODE:-prefer}"
            local _conn="postgresql://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${_sslmode}"
            if ! psql "${_conn}" -c "SELECT 1;" > /dev/null 2>&1; then
                print_error "Cannot connect to ${DB_HOST}:${DB_PORT}/${DB_NAME} (sslmode=${_sslmode}) - exiting before any migrations run"
                psql "${_conn}" -c "SELECT 1;"
                exit 1
            fi
            if psql "${_conn}" -tAc "SELECT to_regclass('public.${_table}');" 2>/dev/null \
                    | tr -d ' ' | grep -qx "${_table}"; then
                return 0
            fi
            return 1
        ;;
        * )
            print_error "[laravel_db_is_populated] Unsupported DB_TYPE '${DB_TYPE}' - set DB_TYPE to 'mariadb / mysql / pgsql / postgres / sqlite'"
            exit 1
        ;;
    esac
}

laravel_nginx_prune_fragments() {
    # Downstream image helper sites.available/<site>/location/40-app-router.conf with its own location /.
    local _site _fragment
    for _site in $(echo "${NGINX_SITE_ENABLED}" | tr ',' ' '); do
        if var_false "${LARAVEL_NGINX_ENABLE_ROUTER}"; then
            _fragment="${NGINX_CONFIG_PATH%/}/sites.enabled/${_site}/location/30-01-router.conf"
            if [ -e "${_fragment}" ] || [ -L "${_fragment}" ]; then
                print_debug "[laravel_nginx_prune_fragments] LARAVEL_NGINX_ENABLE_ROUTER=FALSE - removing ${_fragment}"
                rm -f "${_fragment}"
            fi
        fi
        if var_false "${LARAVEL_NGINX_ENABLE_STATIC_PATHS}"; then
            _fragment="${NGINX_CONFIG_PATH%/}/sites.enabled/${_site}/location/30-02-static_paths.conf"
            if [ -e "${_fragment}" ] || [ -L "${_fragment}" ]; then
                print_debug "[laravel_nginx_prune_fragments] LARAVEL_NGINX_ENABLE_STATIC_PATHS=FALSE - removing ${_fragment}"
                rm -f "${_fragment}"
            fi
        fi
    done
}

laravel_setup_webroot() {
    if [ ! -f "${NGINX_WEBROOT%/}/artisan" ]; then
        chown -R "${NGINX_USER}":"${NGINX_GROUP}" \
                                                    "${NGINX_WEBROOT}" \
                                                    /var/cache/nginx

        transform_var file LARAVEL_GIT_REPO
        if [ -n "${LARAVEL_GIT_REPO}" ]; then
            print_debug "[setup_webroot] branch: git clone - LARAVEL_GIT_REPO is set"
            _laravel_acquire_from_git
            _laravel_post_source_setup
        elif [ -d "${LARAVEL_INSTALL_DATA_PATH%/}/install" ] && dir_notempty "${LARAVEL_INSTALL_DATA_PATH%/}/install" ; then
            print_debug "[setup_webroot] -> branch: install-from-data ('${LARAVEL_INSTALL_DATA_PATH%/}/install')"
            _laravel_acquire_from_data_path
            _laravel_post_source_setup
        else
            print_debug "[setup_webroot]  branch: composer create-project"
            print_warn "Potential New Installation / Standalone Laravel Application detected"
            print_info "Installing Base Laravel Application"
            cd "${NGINX_WEBROOT}"

            silent sudo -u "${NGINX_USER}" \
                                    composer create-project \
                                        laravel/laravel \
                                            "${NGINX_WEBROOT}" \
                                                --no-interaction \
                                                --no-progress \
                                                --no-scripts \
                                                --prefer-dist

            if [ -f "${NGINX_WEBROOT%/}"/package.json ]; then
                print_info "Installing Node dependencies"
                silent sudo -u "${NGINX_USER}" \
                                                 npm \
                                                    install
            fi
        fi
    fi

    if [ ! -f "${NGINX_WEBROOT%/}"/.gitignore ] && [ -f "${LARAVEL_INSTALL_DATA_PATH}/gitignore" ] ; then
        print_debug "[setup_webroot] Creating .gitignore file"
        cat "${LARAVEL_INSTALL_DATA_PATH}"/gitignore | write_file "${NGINX_USER}" "${NGINX_WEBROOT%/}"/.gitignore:644
    fi
}

laravel_strip_path_repos() {
    # Remove type: path Composer repositories from composer.json.
    # Nfrastack only purpose
    if [ ! -f "${NGINX_WEBROOT%/}"/composer.json ]; then
        return
    fi
    _result=$(php -r '
        $f = $argv[1];
        $j = json_decode(file_get_contents($f), true);
        if (isset($j["repositories"]) && is_array($j["repositories"])) {
            $before = count($j["repositories"]);
            $j["repositories"] = array_values(array_filter($j["repositories"], fn($r) => ($r["type"] ?? "") !== "path"));
            if (count($j["repositories"]) < $before) {
                file_put_contents($f, json_encode($j, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
                echo "removed";
            }
        }
    ' "${NGINX_WEBROOT%/}"/composer.json 2>/dev/null)
    if [ "${_result}" = "removed" ]; then
        print_debug "Stripped local path repositories from composer.json"
    fi
}

laravel_setup_container_mode() {
    modes=$(echo "${LARAVEL_IMAGE_MODE}" | tr "," "\n")
    for mode in $modes; do
        case "${mode,,}" in
            prod* )
                print_info "Laravel Image: Production Mode"
                ENABLE_LARAVEL_ARTISAN_SERVE=${ENABLE_LARAVEL_ARTISAN_SERVE:-FALSE}
                ENABLE_LARAVEL_NPM_RUN_DEV=${ENABLE_LARAVEL_NPM_RUN_DEV:-FALSE}
                ENABLE_LARAVEL_WORKER=${ENABLE_LARAVEL_WORKER:-TRUE}
                ENABLE_CONFIG_REDIRECTION=${ENABLE_CONFIG_REDIRECTION:-TRUE}
                ENABLE_LOG_REDIRECTION=${ENABLE_LOG_REDIRECTION:-TRUE}
                ENABLE_STORAGE_REDIRECTION=${ENABLE_STORAGE_REDIRECTION:-TRUE}
            ;;
            develop* | * )
                print_info "Laravel Image: Development Mode"
                ENABLE_LARAVEL_ARTISAN_SERVE=${ENABLE_LARAVEL_ARTISAN_SERVE:-TRUE}
                ENABLE_LARAVEL_NPM_RUN_DEV=${ENABLE_LARAVEL_NPM_RUN_DEV:-TRUE}
                ENABLE_LARAVEL_WORKER=${ENABLE_LARAVEL_WORKER:-"TRUE"}
                ENABLE_CONFIG_REDIRECTION=${ENABLE_CONFIG_REDIRECTION:-FALSE}
                ENABLE_LOG_REDIRECTION=${ENABLE_LOG_REDIRECTION:-FALSE}
                ENABLE_STORAGE_REDIRECTION=${ENABLE_STORAGE_REDIRECTION:-FALSE}
            ;;
        esac
    done
}

laravel_update_bashrc() {
    if check_container_restarted ; then
        write_file -a root:root@/root/.bashrc <<EOF
artisan() {
    export oldpwd="\$(pwd)"
    cd ${NGINX_WEBROOT}
    sudo -u ${NGINX_USER} php "${NGINX_WEBROOT%/}"/artisan "\$@"
    cd "\${oldpwd}"
}
EOF
    fi
}

laravel_volatile_setup() {
    case "${@,,}" in
        config )
            if [ ! -d "${CONFIG_PATH}" ]; then
                print_info "Creating Config Directory"
                create_folder \
                                "${CONFIG_PATH}" \
                                "${NGINX_USER}":"${NGINX_GROUP}" 775
            fi

            _already_redirected=false
            if [ -L "${NGINX_WEBROOT%/}"/.env ]; then
                _target=$(readlink "${NGINX_WEBROOT%/}"/.env)
                if [ "${_target}" = "${CONFIG_PATH%/}/${CONFIG_FILE}" ]; then
                    _already_redirected=true
                    print_debug "Config already redirected to '${CONFIG_PATH%/}/${CONFIG_FILE}'"
                fi
            fi

            if ! ${_already_redirected}; then
                if [ -s "${NGINX_WEBROOT%/}"/.env ] && [ ! -L "${NGINX_WEBROOT%/}"/.env ]; then
                    if [ ! -s "${CONFIG_PATH%/}"/"${CONFIG_FILE}" ]; then
                        print_info "Copying .env to Config Directory"
                        cp "${NGINX_WEBROOT%/}"/.env "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                    else
                        print_warn "Config File already exists, skipping copy"
                    fi
                fi
                rm -rf "${NGINX_WEBROOT%/}"/.env
                ln -sf "${CONFIG_PATH%/}"/"${CONFIG_FILE}" "${NGINX_WEBROOT%/}"/.env
            fi

            if [ ! -e "${CONFIG_PATH%/}"/"${CONFIG_FILE}" ]; then
                sudo -u "${NGINX_USER}" touch "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                chmod 660 "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${CONFIG_PATH}"
        ;;
        log )
            if [ ! -d "${LOG_PATH}" ]; then
                print_info "Creating Log Directory"
                create_folder \
                                "${LOG_PATH}" \
                                "${NGINX_USER}":"${NGINX_GROUP}" 770
            fi

            if [ ! -d "${NGINX_WEBROOT%/}"/storage ]; then
                sudo -u "${NGINX_USER}" mkdir -p "${NGINX_WEBROOT%/}"/storage
            fi

            rm -rf "${NGINX_WEBROOT%/}"/storage/logs
            ln -sf "${LOG_PATH}" "${NGINX_WEBROOT%/}"/storage/logs
            create_logrotate laravel "${LOG_PATH%/}"/"${LOG_FILE}"
        ;;
        storage )
            if [ ! -d "${STORAGE_PATH}" ]; then
                print_info "Creating Storage Directory"
                create_folder \
                                "${STORAGE_PATH}" \
                                "${NGINX_USER}":"${NGINX_GROUP}" 775
            fi

            _already_redirected=false
            if [ -L "${NGINX_WEBROOT%/}"/storage ]; then
                _target=$(readlink "${NGINX_WEBROOT%/}"/storage)
                case "${_target}" in
                    "${STORAGE_PATH}"|"${STORAGE_PATH%/}")
                        _already_redirected=true
                        print_debug "Storage already redirected to '${STORAGE_PATH}'"
                    ;;
                esac
            fi

            if ! ${_already_redirected}; then
                if [ -d "${NGINX_WEBROOT%/}"/storage ] && [ ! -L "${NGINX_WEBROOT%/}"/storage ] && dir_empty "${STORAGE_PATH%/}"; then
                    cp -aR "${NGINX_WEBROOT%/}"/storage/. "${STORAGE_PATH%/}"/
                fi
                rm -rf "${NGINX_WEBROOT%/}"/storage
                ln -s "${STORAGE_PATH}" "${NGINX_WEBROOT%/}"/storage
            fi

            create_folder \
                "${STORAGE_PATH%/}/app,\
                ${STORAGE_PATH%/}/app/public,\
                ${STORAGE_PATH%/}/framework,\
                ${STORAGE_PATH%/}/framework/cache,\
                ${STORAGE_PATH%/}/framework/cache/data,\
                ${STORAGE_PATH%/}/framework/sessions,\
                ${STORAGE_PATH%/}/framework/testing,\
                ${STORAGE_PATH%/}/framework/views,\
                ${STORAGE_PATH%/}/logs" \
                "${NGINX_USER}":"${NGINX_GROUP}" 775 norecurse force
        ;;
    esac
}
