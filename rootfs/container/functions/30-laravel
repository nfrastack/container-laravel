_laravel_acquire_from_git() {
    print_notice "Cloning Application from Git Repository"
    local _git_url="${LARAVEL_GIT_REPO}"
    transform_var file LARAVEL_GIT_TOKEN
    if [ -n "${LARAVEL_GIT_TOKEN}" ]; then
        _git_url=$(echo "${_git_url}" | sed "s|://|://${LARAVEL_GIT_TOKEN}@|")
    fi

    silent sudo -u "${NGINX_USER}" \
                            git clone \
                                --branch "${LARAVEL_GIT_BRANCH}" \
                                --single-branch \
                                --depth 1 \
                                "${_git_url}" \
                                "${NGINX_WEBROOT%/}"/tmp-clone
    local _exit_code=$?
    if [ "${_exit_code}" -ne 0 ]; then
        print_error "Git clone failed (exit code ${_exit_code}) - retrying with output visible"
        rm -rf "${NGINX_WEBROOT%/}"/tmp-clone
        sudo -u "${NGINX_USER}" \
                            git clone \
                                --branch "${LARAVEL_GIT_BRANCH}" \
                                --single-branch \
                                --depth 1 \
                                "${_git_url}" \
                                "${NGINX_WEBROOT%/}"/tmp-clone
        exit 1
    fi

    shopt -s dotglob
    mv "${NGINX_WEBROOT%/}"/tmp-clone/* "${NGINX_WEBROOT%/}"/
    shopt -u dotglob
    rm -rf "${NGINX_WEBROOT%/}"/tmp-clone
}

_laravel_acquire_from_data_path() {
    local _src="${LARAVEL_INSTALL_DATA_PATH%/}/install"
    print_notice "Installing application from source at '${_src}'"
    cp -aR "${_src}/." "${NGINX_WEBROOT%/}/"
    chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}"
}

laravel_artisan_setup_commands() {
    # Commands are newline- or pipe (|)-separated artisan sub-commands (everything after artisan eg 'migrate --force')
    # Variables
    #   LARAVEL_ARTISAN_SETUP_COMMANDS      — unnumbered catch-all - runs first
    #   LARAVEL_ARTISAN_SETUP_COMMANDS01    — slot 01
    #   LARAVEL_ARTISAN_SETUP_COMMANDS02    — slot 02
    _slot="${1:-}"

    if [ -n "${_slot}" ]; then
        _laravel_artisan_cmd_slot "${_slot}"
    else
        _ran=0
        if [ -n "${LARAVEL_ARTISAN_SETUP_COMMANDS}" ]; then
            cd "${NGINX_WEBROOT}"
            print_info "Running artisan setup commands"
            _laravel_run_artisan_cmds "${LARAVEL_ARTISAN_SETUP_COMMANDS}"
            _ran=$((_ran + 1))
        fi
        _count=$(printenv | grep -cE '^LARAVEL_ARTISAN_SETUP_COMMANDS_[0-9]' || true)
        if [ "${_count:-0}" -gt 0 ]; then
            floop "${_count}" _laravel_artisan_cmd_slot SDNAMMOC_PUTES_NASITRA_LEVARAL
            _ran=$((_ran + 1))
        fi
        if [ "${_ran}" -eq 0 ] ; then print_debug "No artisan setup commands defined - skipping" ; fi
    fi
}

_laravel_artisan_cmd_slot() {
    local i="${1}"
    i=$(printf "%02d" "$i")
    local _var="LARAVEL_ARTISAN_SETUP_COMMANDS${i}"
    local _cmds="${!_var}"
    if [ -z "${_cmds}" ]; then
        print_debug "[artisan_cmd] No commands defined in ${_var} — skipping"
        return
    fi
    print_info "[artisan_cmd] Running artisan setup commands (slot ${i})"
    _laravel_run_artisan_cmds "${_cmds}"
}

_laravel_run_artisan_cmds() {
    printf '%s\n' "${1}" | tr '|' '\n' | while IFS= read -r _cmd; do
        _cmd=$(printf '%s' "${_cmd}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "${_cmd}" ] && continue
        case "${_cmd}" in \#*) continue ;; esac
        print_debug "Artisan: php "${NGINX_WEBROOT%/}"/artisan ${_cmd}"
        if ! silent sudo -u "${NGINX_USER}" sh -c "php ${NGINX_WEBROOT}/artisan ${_cmd}"; then
            print_error "Artisan command failed: '${_cmd}' — retrying with output visible"
            sudo -u "${NGINX_USER}" sh -c "php ${NGINX_WEBROOT}/artisan ${_cmd}"
            exit 1
        fi
    done
}

_laravel_post_source_setup() {
    # Seed .env from .env.example only when LARAVEL_COPY_ENV_EXAMPLE=TRUE.
    if var_true "${LARAVEL_COPY_ENV_EXAMPLE}" \
            && [ ! -f "${NGINX_WEBROOT%/}"/.env ] \
            && [ -f "${NGINX_WEBROOT%/}"/.env.example ]; then
        print_debug "Copying .env.example to .env"
        cp "${NGINX_WEBROOT%/}"/.env.example "${NGINX_WEBROOT%/}"/.env
        chown "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT%/}"/.env
    fi

    if var_true "${LARAVEL_COMPOSER_SETUP}" ; then
        cd "${NGINX_WEBROOT}"
        laravel_strip_path_repos
        print_info "Running Composer Install"
        transform_var file LARAVEL_COMPOSER_AUTH
        if [ -n "${LARAVEL_COMPOSER_AUTH}" ]; then
            print_debug "Using provided Composer authentication"
            silent sudo -u "${NGINX_USER}" \
                                    COMPOSER_AUTH="${LARAVEL_COMPOSER_AUTH}" \
                                    composer install \
                                        --no-interaction \
                                        --no-progress
        else
            silent sudo -u "${NGINX_USER}" \
                                    composer install \
                                        --no-interaction \
                                        --no-progress
        fi
        local _exit_code=$?
        if [ "${_exit_code}" -ne 0 ]; then
            print_error "Composer install failed (exit code ${_exit_code}) - retrying with output visible"
            if [ -n "${LARAVEL_COMPOSER_AUTH}" ]; then
                sudo -u "${NGINX_USER}" \
                                    COMPOSER_AUTH="${LARAVEL_COMPOSER_AUTH}" \
                                    composer install \
                                        --no-interaction \
                                        --no-progress
            else
                sudo -u "${NGINX_USER}" \
                                    composer install \
                                        --no-interaction \
                                        --no-progress
            fi
            exit 1
        fi
    fi

    if var_true "${LARAVEL_MIGRATE_ON_FIRST_INSTALL}" ; then
        cd "${NGINX_WEBROOT}"
        if grep -qi "DB_CONNECTION=sqlite" "${NGINX_WEBROOT%/}"/.env 2>/dev/null; then
            local _db_path
            _db_path=$(grep -i "^DB_DATABASE=" "${NGINX_WEBROOT%/}"/.env 2>/dev/null | cut -d'=' -f2 | sed 's/#.*//' | tr -d '"' | tr -d "'" | xargs)
            if [ -n "${_db_path}" ] && [ "${_db_path}" != ":memory:" ]; then
                case "${_db_path}" in
                    /*) ;;
                    *)  _db_path="${NGINX_WEBROOT%/}/${_db_path}" ;;
                esac
                if [ ! -f "${_db_path}" ]; then
                    print_info "Creating SQLite database at '${_db_path}'"
                    sudo -u "${NGINX_USER}" touch "${_db_path}"
                fi
            fi
        fi

        print_info "Running database migrations"
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/artisan migrate --force
        local _migrate_code=$?
        if [ "${_migrate_code}" -ne 0 ]; then
            print_error "Database migration failed (exit code ${_migrate_code}) - retrying with output visible"
            sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/artisan migrate --force
            exit 1
        fi

        laravel_artisan_setup_commands
    fi

    if var_true "${LARAVEL_NPM_SETUP}" ; then
        print_info "Installing Node dependencies"
        cd "${NGINX_WEBROOT}"
        silent sudo -u "${NGINX_USER}" npm install
        local _npm_code=$?
        if [ "${_npm_code}" -ne 0 ]; then
            print_error "npm install failed (exit code ${_npm_code}) - retrying with output visible"
            sudo -u "${NGINX_USER}" npm install
            exit 1
        fi

        print_info "Building frontend assets"
        silent sudo -u "${NGINX_USER}" npm run build
        local _build_code=$?
        if [ "${_build_code}" -ne 0 ]; then
            print_error "npm run build failed (exit code ${_build_code}) - retrying with output visible"
            sudo -u "${NGINX_USER}" npm run build
            exit 1
        fi
    fi
}

laravel_env_get() {
    # laravel_env_get KEY
    # Read the current value of KEY from the application .env. Returns empty string if the file does not exist or the key is not present.
    local _key="$1"
    local _env="${NGINX_WEBROOT%/}/.env"

    if [ ! -f "${_env}" ]; then
        return
    fi

    awk -v key="${_key}=" 'index($0, key) == 1 { print substr($0, length(key) + 1); exit }' "${_env}"
}

laravel_env_passthrough() {
    #   ENV_FOO=bar                 -     .env line `FOO=bar`  (added or rewritten)
    #   ENV_FOO=unset|null|""       -     .env line `FOO=bar`  (removed)
    #   ENV_FOO=env:OTHER_VAR       -     resolved via transform_var env before write
    #   ENV_FOO_FILE=/path/secret   -     resolved via transform_var file before write

    local _prefix="${LARAVEL_ENV_PREFIX}"
    if [ -z "${_prefix}" ]; then
        print_debug "[env_passthrough] LARAVEL_ENV_PREFIX is empty - skipping env-prefix pass-through"
        return
    fi
    if [ ! -f "${NGINX_WEBROOT%/}"/.env ]; then
        print_debug "[env_passthrough] No .env file present - skipping env-prefix pass-through"
        return
    fi

    transform_var file "${_prefix}*"
    transform_var env  "${_prefix}*"

    print_debug "[env_passthrough] Applying passthrough (prefix='${_prefix}')"

    local _line _name _stripped _value
    while IFS= read -r _line; do
        _name="${_line%%=*}"
        case "${_name}" in
            "${_prefix}"*) ;;
            *) continue ;;
        esac


        # Skip container-owned LARAVEL_* control variables when LARAVEL_ENV_PREFIX=LARAVEL_
        case "${_name}" in
            LARAVEL_ENV_PREFIX|LARAVEL_GIT_*|LARAVEL_COMPOSER_*|LARAVEL_NPM_*|LARAVEL_ADMIN_*|LARAVEL_ARTISAN_SETUP_COMMANDS*|LARAVEL_IMAGE_MODE|LARAVEL_CONFIGURE_*|LARAVEL_INSTALL_DATA_PATH|LARAVEL_COPY_ENV_EXAMPLE|LARAVEL_MIGRATE_ON_FIRST_INSTALL|LARAVEL_DB_FRESH_CHECK_TABLE) continue ;;
        esac

        case "${_name}" in
            *_FILE) continue ;;
        esac

        _stripped="${_name#${_prefix}}"
        if [ -z "${_stripped}" ]; then
            continue
        fi
        _value="${_line#*=}"

        case "${_value,,}" in
            unset|null|"")
                laravel_env_remove "${_stripped}"
            ;;
            *)
                laravel_env_update "${_stripped}" "${_value}"
            ;;
        esac
    done < <(printenv)
}

laravel_env_remove() {
    # laravel_env_remove KEY
    local _key="$1"
    local _env="${NGINX_WEBROOT%/}/.env"
    local _tmp

    if [ ! -f "${_env}" ]; then
        return
    fi
    if ! grep -qE "^${_key}=" "${_env}" 2>/dev/null; then
        return
    fi

    print_debug "[env_remove] Removing .env entry '${_key}'"

    _tmp="${_env}.tmp.$$"
    LARAVEL_ENV_KEY="${_key}" awk '
        BEGIN { key = ENVIRON["LARAVEL_ENV_KEY"] "=" }
        index($0, key) == 1 { next }
        { print }
    ' "${_env}" > "${_tmp}"
    cat "${_tmp}" > "${_env}"
    rm -f "${_tmp}"
}

laravel_env_update() {
    # laravel_env_update KEY VALUE
    # Set or update a key=value pair in the application .env
    # Values containing whitespace are double-quoted.
    local _key="$1"
    local _val="$2"
    local _env="${NGINX_WEBROOT%/}/.env"
    local _line _tmp

    if [ ! -f "${_env}" ]; then
        print_debug "No .env file - skipping update for '${_key}'"
        return
    fi

    if [[ ${_val} = *[[:space:]]* ]]; then
        _line="${_key}=\"${_val}\""
    else
        _line="${_key}=${_val}"
    fi

    print_debug "[env_update] Setting .env '${_key}' = '${_val}'"

    _tmp="${_env}.tmp.$$"
    LARAVEL_ENV_KEY="${_key}" LARAVEL_ENV_LINE="${_line}" awk '
        BEGIN {
            key   = ENVIRON["LARAVEL_ENV_KEY"] "="
            line  = ENVIRON["LARAVEL_ENV_LINE"]
            found = 0
        }
        index($0, key) == 1 {
            if (!found) { print line; found = 1 }
            next
        }
        { print }
        END { if (!found) print line }
    ' "${_env}" > "${_tmp}"
    cat "${_tmp}" > "${_env}"
    rm -f "${_tmp}"
}

laravel_env_write_header() {
    # Write header to brand new .env file with instructions for users. Does nothing if .env already exists and is not empty to avoid overwriting existing config or comments.
    local _env_file="${NGINX_WEBROOT%/}/.env"

    if [ -s "${_env_file}" ]; then
        return
    fi

    local _prefix="${LARAVEL_ENV_PREFIX}"

    print_debug "[env_write_header] Writing header to new .env (prefix='${_prefix}')"

    write_file "${NGINX_USER}":"${NGINX_GROUP}"@"${_env_file}":660 << EOF
## Auto-generated by ${IMAGE_NAME} | ## First Generated on $(TZ=${TIMEZONE} date +'%Y-%m-%d %H:%M:%S %Z')
## This file is managed by the container at startup - Values are written at container startup
##  To set or change a value, set an environment variable on the container using the prefix '${_prefix}'. The prefix is stripped before writing
##
##   ${_prefix}APP_DEBUG=true            -> APP_DEBUG=true
##   ${_prefix}MAIL_HOST=postfix-relay   -> MAIL_HOST=postfix-relay
##
## To remove a key, set its env var to one of: 'unset', 'null', or empty:
##
##   ${_prefix}APP_DEBUG=unset
##   ${_prefix}APP_DEBUG=null#
##   ${_prefix}APP_DEBUG=
##
## Secrets: ${_prefix}<KEY>_FILE=/run/secrets/<name> reads the file contents and populates <KEY>=<contents>.
##
## Alternatively, you can stop this mechanism by setting 'SETUP_TYPE=manual'

EOF
}

laravel_configure_app_key() {
    if var_true "${LARAVEL_CONFIGURE_APP_KEY}" ; then
        transform_var file APP_KEY
        if [ -n "${APP_KEY}" ] ; then
            print_debug "[configure_app_key] Setting APP_KEY from environment variable"
            laravel_env_update APP_KEY "${APP_KEY}"
        elif [ -n "$(laravel_env_get APP_KEY)" ] ; then
            print_debug "[configure_app_key] APP_KEY already present in .env - preserving"
        else
            print_debug "[configure_app_key] No APP_KEY found - generating"
            silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/artisan key:generate
        fi
    fi
}

laravel_configure_db() {
    if var_true "${LARAVEL_CONFIGURE_DB}" ; then
        print_debug "[configure_db] Writing DB config (DB_TYPE='${DB_TYPE}')"
        transform_var file \
                            DB_HOST \
                            DB_NAME \
                            DB_PASS \
                            DB_USER

        case "${DB_TYPE,,}" in
            mariadb | mysql )
                laravel_env_update DB_CONNECTION mysql
                laravel_env_update DB_HOST     "${DB_HOST}"
                laravel_env_update DB_PORT     "${DB_PORT}"
                laravel_env_update DB_DATABASE "${DB_NAME}"
                laravel_env_update DB_USERNAME "${DB_USER}"
                laravel_env_update DB_PASSWORD "${DB_PASS}"
            ;;
            pgsql | postgres* )
                laravel_env_update DB_CONNECTION pgsql
                laravel_env_update DB_HOST     "${DB_HOST}"
                laravel_env_update DB_PORT     "${DB_PORT}"
                laravel_env_update DB_DATABASE "${DB_NAME}"
                laravel_env_update DB_USERNAME "${DB_USER}"
                laravel_env_update DB_PASSWORD "${DB_PASS}"
                if [ -n "${DB_SSL_MODE}" ]; then
                    laravel_env_update DB_SSLMODE "${DB_SSL_MODE}"
                fi
            ;;
            sqlite* )
                laravel_env_update DB_CONNECTION sqlite
                laravel_env_update DB_DATABASE "${DB_NAME}"
                laravel_env_remove DB_HOST
                laravel_env_remove DB_PORT
                laravel_env_remove DB_USERNAME
                laravel_env_remove DB_PASSWORD
            ;;
            *)
                print_error "[configure_db] Unsupported DB_TYPE='${DB_TYPE}' - Use 'mariadb, mysql, pgsql/postgres, sqlite'"
                exit 1
            ;;
        esac
    fi
}

