case "${DB_TYPE,,}" in
    "mysql" | "mariadb")
        DB_PORT=${DB_PORT:-"3306"}
    ;;
    "pgsql" | postgres* )
        DB_PORT=${DB_PORT:-"5432"}
    ;;
    sqlite* | * )
        DB_PORT=""
    ;;
esac